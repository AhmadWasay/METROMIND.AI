# Backend Environment Variables

# Email Configuration (Gmail)
GMAIL_ADDRESS=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-specific-password

# SMS Configuration - Choose ONE:

# Option 1: Twilio (Free tier available)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=your-twilio-phone-number

# Option 2: Africa's Talking (Has free tier for Pakistan)
AFRICASTALKING_API_KEY=your-africastalking-api-key
AFRICASTALKING_USERNAME=your-africastalking-username

# Admin Token (Change this in production)
ADMIN_TOKEN=admin_secret

# Database
DATABASE_PATH=metromind.db

# Flask Configuration
FLASK_ENV=production
FLASK_DEBUG=False
